def engineer_mta(df):
    df = df.copy()
    df.columns = df.columns.str.strip()
    df["Fare Evasion"] = pd.to_numeric(df["Fare Evasion"], errors="coerce")
    df[["year", "quarter"]] = df["Time Period"].str.extract(r"(\d{4})-Q(\d)").astype(int)
    df["quarter_index"] = (df["year"] - df["year"].min()) * 4 + df["quarter"]
    df["approx_date"] = pd.to_datetime(
        df["year"].astype(str) + "-" + ((df["quarter"] - 1) * 3 + 1).astype(str).str.zfill(2) + "-01"
    )

    df["pre_covid"] = (df["approx_date"] < COVID_START).astype(int)
    df["covid_period"] = ((df["approx_date"] >= COVID_START) & (df["approx_date"] < RECOVERY)).astype(int)
    df["post_covid"] = (df["approx_date"] >= RECOVERY).astype(int)
    df["quarters_since_covid"] = ((df["approx_date"] - COVID_START).dt.days / 91.25).clip(lower=0)

    le = LabelEncoder()
    df["trip_type_enc"] = le.fit_transform(df["Trip Type"])
    df = df.sort_values(["Trip Type", "quarter_index"]).reset_index(drop=True)

    for lag in [1, 2, 4]:
        df[f"evasion_lag{lag}"] = df.groupby("Trip Type")["Fare Evasion"].shift(lag)
    df["evasion_roll4"] = df.groupby("Trip Type")["Fare Evasion"].transform(lambda x: x.shift(1).rolling(4).mean())

    def rolling_slope(series):
        result = series.copy() * np.nan
        for i in range(4, len(series)):
            y_vals = series.iloc[i - 4 : i].values
            if not np.any(np.isnan(y_vals)):
                result.iloc[i] = np.polyfit(range(4), y_vals, 1)[0]
        return result

    df["evasion_trend"] = df.groupby("Trip Type")["Fare Evasion"].transform(rolling_slope)
    df["q_sin"] = np.sin(2 * np.pi * df["quarter"] / 4)
    df["q_cos"] = np.cos(2 * np.pi * df["quarter"] / 4)
    return df.dropna(subset=["evasion_lag1"])


