def _caltrans_year_sort_key(x):
    """Sort year-like keys (2023, 2024) numerically; fall back to string order."""
    s = str(x)
    return (0, int(s)) if s.isdigit() else (1, s)


def discover_caltrans_sessions(downloads_dir: Path):
    """One bicycle + pedestrian file per year; prefer duplicates without ' (1)'."""
    out_bike = []
    out_ped = []
    for pattern, bucket in (
        ("caltrans_bicycle_hourly_count_*.csv", out_bike),
        ("caltrans_pedestrian_hourly_count_*.csv", out_ped),
    ):
        by_year = {}
        for p in sorted(downloads_dir.glob(pattern)):
            stem = p.stem
            parts = stem.replace(" ", "").split("_")
            year_key = parts[-1] if parts and parts[-1].isdigit() else p.name
            prefer = 0 if " (1)" in p.name else 1
            t = p.stat().st_mtime
            prev = by_year.get(year_key)
            if prev is None or (prefer, t) > (prev[0], prev[1]):
                by_year[year_key] = (prefer, t, p)
        for yk in sorted(by_year.keys(), key=_caltrans_year_sort_key):
            bucket.append(by_year[yk][2])
    return out_bike, out_ped


def concat_csvs(paths, label):
    if not paths:
        print(f"  WARNING: no CSVs found for {label}")
        return pd.DataFrame()
    frames = []
    for p in paths:
        frames.append(pd.read_csv(p))
        print(f"    {label}: {p.name} ({len(frames[-1]):,} rows)")
    return pd.concat(frames, ignore_index=True)


