def caltrans_feature_row(dt: pd.Timestamp, med: pd.Series) -> dict:
    """One synthetic hourly row: calendar from dt, spatial/encoded fields from training medians."""
    dt = pd.Timestamp(dt)
    _hm = med.get("hour", 12)
    hour = int(np.round(_hm)) if pd.notna(_hm) else 12
    dow = int(dt.dayofweek)
    month = int(dt.month)
    week = int(dt.isocalendar().week)
    dayofyear = int(dt.dayofyear)
    pre_covid = int(dt < COVID_START)
    covid_lockdown = int((dt >= COVID_START) & (dt < RECOVERY))
    post_covid = int(dt >= RECOVERY)
    months_since_covid = max(0.0, (dt - COVID_START).days / 30.44)
    return {
        "latitude": med["latitude"],
        "longitude": med["longitude"],
        "district": med["district"],
        "hour": hour,
        "dow": dow,
        "month": month,
        "week": week,
        "dayofyear": dayofyear,
        "hour_sin": np.sin(2 * np.pi * hour / 24),
        "hour_cos": np.cos(2 * np.pi * hour / 24),
        "dow_sin": np.sin(2 * np.pi * dow / 7),
        "dow_cos": np.cos(2 * np.pi * dow / 7),
        "month_sin": np.sin(2 * np.pi * month / 12),
        "month_cos": np.cos(2 * np.pi * month / 12),
        "is_weekend": int(dow >= 5),
        "is_am_peak": int(7 <= hour <= 9),
        "is_pm_peak": int(16 <= hour <= 19),
        "direction_enc": med["direction_enc"],
        "count_type_enc": med["count_type_enc"],
        "is_bicycle": med["is_bicycle"],
        "pre_covid": pre_covid,
        "covid_lockdown": covid_lockdown,
        "post_covid": post_covid,
        "months_since_covid": months_since_covid,
    }


