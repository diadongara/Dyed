print("=" * 60)


def compute_behavior_windows(g):
    """Return two subsets of rows for a single loc_id group."""
    g = g.sort_values("datetime")
    pre_m = g["datetime"] < COVID_START
    post_m = g["datetime"] >= RECOVERY
    if pre_m.sum() >= 24 and post_m.sum() >= 24:
        a, b = g[pre_m], g[post_m]
        mode = "pre_post_covid"
    else:
        med = g["datetime"].median()
        a, b = g[g["datetime"] < med], g[g["datetime"] >= med]
        mode = "early_late_split"
        if len(a) < 24 or len(b) < 24:
            return None
    return a, b, mode


rows = []
if "loc_id" not in combined.columns:
    print("  No loc_id column — skip sensor clustering.")
else:
    for loc_id, g in combined.groupby("loc_id"):
        out = compute_behavior_windows(g)
        if out is None:
            continue
        a, b, mode = out

        def stats(block):
            mu = block["count"].mean()
            sd = block["count"].std()
            return {
                "mean": mu,
                "cv": sd / (mu + 1e-6),
                "weekend_share": block["is_weekend"].mean(),
                "am_peak_share": block["is_am_peak"].mean(),
                "pm_peak_share": block["is_pm_peak"].mean(),
                "bike_share": (block["mode_label"] == "Bicycle").mean(),
            }

        sa, sb = stats(a), stats(b)
        rows.append(
            {
                "loc_id": loc_id,
                "district": g["district"].iloc[0],
                "split_mode": mode,
                "log_mean_a": np.log1p(sa["mean"]),
                "log_mean_b": np.log1p(sb["mean"]),
                "delta_log_mean": np.log1p(sb["mean"]) - np.log1p(sa["mean"]),
                "delta_cv": sb["cv"] - sa["cv"],
                "delta_weekend": sb["weekend_share"] - sa["weekend_share"],
                "delta_am_peak": sb["am_peak_share"] - sa["am_peak_share"],
                "delta_bike_share": sb["bike_share"] - sa["bike_share"],
                "n_a": len(a),
                "n_b": len(b),
            }
        )

    cluster_df = pd.DataFrame(rows)
    print(f"  Sensors with enough data for two-window contrast: {len(cluster_df)}")

    if len(cluster_df) >= 8:
        clust_feats = [
            "delta_log_mean",
            "delta_cv",
            "delta_weekend",
            "delta_am_peak",
            "delta_bike_share",
        ]
        Xc = cluster_df[clust_feats].replace([np.inf, -np.inf], np.nan).fillna(0.0)
        scaler = StandardScaler()
        Xs = scaler.fit_transform(Xc)
        k = min(5, max(2, len(cluster_df) // 15))
        km = KMeans(n_clusters=k, random_state=RANDOM_STATE, n_init=10)
        cluster_df["cluster"] = km.fit_predict(Xs)

        pca = PCA(n_components=2, random_state=RANDOM_STATE)
        xy = pca.fit_transform(Xs)
        cluster_df["pc1"] = xy[:, 0]
        cluster_df["pc2"] = xy[:, 1]

        print(f"  KMeans k={k} | split modes: {cluster_df['split_mode'].value_counts().to_dict()}")

        fig_c, axc = plt.subplots(figsize=(9, 7))
        for c in sorted(cluster_df["cluster"].unique()):
            sub = cluster_df[cluster_df["cluster"] == c]
            axc.scatter(sub["pc1"], sub["pc2"], s=40, alpha=0.75, label=f"Cluster {c}")
        axc.set_xlabel(f"PC1 ({pca.explained_variance_ratio_[0]:.0%} var)")
        axc.set_ylabel(f"PC2 ({pca.explained_variance_ratio_[1]:.0%} var)")
        axc.set_title("Sensor impact clusters (PCA of Δ-behavior features)")
        axc.legend()
        axc.axhline(0, color="grey", lw=0.5)
        axc.axvline(0, color="grey", lw=0.5)
        plt.tight_layout()
        savefig("04_impact_clusters_pca")
        plt.close()

        prof = cluster_df.groupby("cluster")[clust_feats].mean()
        print("\n  Cluster profiles (mean Δ features):")
        print(prof.round(4).to_string())
    else:
        print("  Too few sensors for clustering after filters.")


