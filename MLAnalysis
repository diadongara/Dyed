def mta_next_quarter(year: int, quarter: int):
    if quarter >= 4:
        return year + 1, 1
    return year, quarter + 1


def mta_project_quarters(mta_full: pd.DataFrame, model, n_future: int = 20):
    """Recursive quarter-ahead evasion with seasonal anchor + step cap (reduces fake linear drift)."""
    q_month = {1: 1, 2: 4, 3: 7, 4: 10}
    rows = []
    for tt in sorted(mta_full["Trip Type"].unique()):
        g = mta_full[mta_full["Trip Type"] == tt].sort_values("quarter_index")
        hist = [float(x) for x in g["Fare Evasion"].values]
        seasonal = g.groupby("quarter")["Fare Evasion"].mean().to_dict()
        diffs = np.abs(np.diff(np.asarray(g["Fare Evasion"].values, dtype=float)))
        max_step = float(np.percentile(diffs, 90)) if len(diffs) else 0.03
        max_step = max(max_step, 0.008)
        last = g.iloc[-1]
        cy, cq = int(last["year"]), int(last["quarter"])
        qidx = int(last["quarter_index"])
        prev = hist[-1]
        for _ in range(n_future):
            cy, cq = mta_next_quarter(cy, cq)
            qidx += 1
            approx_date = pd.Timestamp(year=cy, month=q_month[cq], day=1)
            pre = int(approx_date < COVID_START)
            covp = int(COVID_START <= approx_date < RECOVERY)
            post = int(approx_date >= RECOVERY)
            q_sc = max(0.0, (approx_date - COVID_START).days / 91.25)
            e1 = hist[-1]
            e2 = hist[-2] if len(hist) >= 2 else e1
            e4 = hist[-4] if len(hist) >= 4 else e1
            roll4 = float(np.mean(hist[-4:])) if len(hist) >= 4 else float(np.mean(hist))
            ylag = np.array(hist[-4:], dtype=float)
            trend = float(np.polyfit(np.arange(len(ylag)), ylag, 1)[0]) if len(hist) >= 4 else 0.0
            row_dict = {
                "trip_type_enc": int(last["trip_type_enc"]),
                "quarter_index": qidx,
                "q_sin": np.sin(2 * np.pi * cq / 4),
                "q_cos": np.cos(2 * np.pi * cq / 4),
                "evasion_lag1": e1,
                "evasion_lag2": e2,
                "evasion_lag4": e4,
                "evasion_roll4": roll4,
                "evasion_trend": trend,
                "pre_covid": pre,
                "covid_period": covp,
                "post_covid": post,
                "quarters_since_covid": q_sc,
            }
            xrow = pd.DataFrame([row_dict])[MTA_FEATURES]
            raw = float(np.clip(model.predict(xrow)[0], 0.0, 0.95))
            anchor = float(seasonal.get(cq, raw))
            yhat = 0.68 * raw + 0.32 * anchor
            yhat = float(np.clip(yhat, prev - max_step, prev + max_step))
            prev = yhat
            hist.append(yhat)
            rows.append({"Trip Type": tt, "approx_date": approx_date, "Fare_Evasion_proj": yhat})
    return pd.DataFrame(rows)


