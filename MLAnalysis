def engineer_caltrans(df, mode_label):
    df = df.copy()
    df.columns = df.columns.str.strip()
    df["datetime"] = pd.to_datetime(df["date"], utc=False)
    df["hour"] = df["datetime"].dt.hour
    df["dow"] = df["datetime"].dt.dayofweek
    df["month"] = df["datetime"].dt.month
    df["week"] = df["datetime"].dt.isocalendar().week.astype(int)
    df["dayofyear"] = df["datetime"].dt.dayofyear
    df["year"] = df["datetime"].dt.year

    df["hour_sin"] = np.sin(2 * np.pi * df["hour"] / 24)
    df["hour_cos"] = np.cos(2 * np.pi * df["hour"] / 24)
    df["dow_sin"] = np.sin(2 * np.pi * df["dow"] / 7)
    df["dow_cos"] = np.cos(2 * np.pi * df["dow"] / 7)
    df["month_sin"] = np.sin(2 * np.pi * df["month"] / 12)
    df["month_cos"] = np.cos(2 * np.pi * df["month"] / 12)

    df["is_weekend"] = (df["dow"] >= 5).astype(int)
    df["is_am_peak"] = ((df["hour"] >= 7) & (df["hour"] <= 9)).astype(int)
    df["is_pm_peak"] = ((df["hour"] >= 16) & (df["hour"] <= 19)).astype(int)

    df["pre_covid"] = (df["datetime"] < COVID_START).astype(int)
    df["covid_lockdown"] = ((df["datetime"] >= COVID_START) & (df["datetime"] < RECOVERY)).astype(int)
    df["post_covid"] = (df["datetime"] >= RECOVERY).astype(int)
    df["months_since_covid"] = ((df["datetime"] - COVID_START).dt.days / 30.44).clip(lower=0)

    le_dir = LabelEncoder()
    df["direction_enc"] = le_dir.fit_transform(df["direction"].astype(str))
    le_ct = LabelEncoder()
    df["count_type_enc"] = le_ct.fit_transform(df["count_type"].astype(str))

    df["mode_label"] = mode_label
    df = df.dropna(subset=["count"])
    df["count"] = df["count"].clip(lower=0)
    return df


