import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import numpy as np
from matplotlib.lines import Line2D

# load the dataset
df = pd.read_csv("/Users/divyar/Downloads/MTA_Bus_Fare_Evasion__Beginning_2019.csv")

# Convert Fare Evasion to percentage
df["Fare Evasion %"] = df["Fare Evasion"] * 100

# Plot each Trip Type as a separate line
fig, ax = plt.subplots(figsize=(12, 6))

trip_types = df["Trip Type"].unique()
colors = plt.cm.tab10.colors

label_map = {
    "Express": "Express",
    "Local": "Local/Limited",
    "SBS": "Select Bus Service (SBS)",
}

# Build a sorted list of all unique time periods as the x-axis
all_periods = sorted(df["Time Period"].unique())
x_indices = {period: i for i, period in enumerate(all_periods)}

legend_handles = []
legend_labels = []

for i, trip in enumerate(trip_types):
    subset = df[df["Trip Type"] == trip].sort_values("Time Period")
    x_vals = [x_indices[p] for p in subset["Time Period"]]
    y_vals = subset["Fare Evasion %"].values
    color = colors[i % len(colors)]
    full_label = label_map.get(trip, trip)

    # Plot actual data line
    data_line, = ax.plot(
        x_vals,
        y_vals,
        marker="o",
        linewidth=2.2,
        markersize=6,
        color=color,
    )
    legend_handles.append(data_line)
    legend_labels.append(full_label)

    # Plot trendline (linear regression) — requires at least 2 points
    x_arr = np.array(x_vals)
    if len(x_arr) < 2:
        continue
    coeffs = np.polyfit(x_arr, y_vals, 1)
    trendline = np.poly1d(coeffs)
    padding = (x_arr.max() - x_arr.min()) * 0.05
    x_range = np.linspace(x_arr.min() - padding, x_arr.max() + padding, 200)
    trend_line, = ax.plot(
        x_range,
        trendline(x_range),
        linestyle="--",
        linewidth=2.5,
        color=color,
        alpha=1.0,
        zorder=5,
    )
    legend_handles.append(trend_line)
    legend_labels.append(f"{full_label} (trend)")

ax.set_xticks(range(len(all_periods)))
ax.set_xticklabels(all_periods)

# styling
ax.set_title("MTA Bus Fare Evasion Over Time", fontsize=16, fontweight="bold", pad=15)
ax.set_xlabel("Time Period", fontsize=12)
ax.set_ylabel("Fare Evasion Rate (%)", fontsize=12)
ax.yaxis.set_major_formatter(mticker.FormatStrFormatter("%.1f%%"))

plt.xticks(rotation=45, ha="right", fontsize=9)

ax.legend(handles=legend_handles, labels=legend_labels, title="Trip Type", bbox_to_anchor=(1.01, 1), loc="upper left", fontsize=10)
ax.grid(axis="y", linestyle="--", alpha=0.5)
ax.spines[["top", "right"]].set_visible(False)

plt.tight_layout()
plt.savefig("/Users/divyar/Downloads/fare_evasion_over_time.png", dpi=150, bbox_inches="tight")
plt.show()
print("Chart saved!")
